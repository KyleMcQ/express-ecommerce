extends layout

block content
    .row.mt-4
        .col-md-12
            h1.mb-4= title
            if cart.length === 0
                .alert.alert-info Your cart is empty.
                a.btn.btn-primary(href='/') Continue Shopping
            else
                .table-responsive
                    table.table.table-hover.align-middle
                        thead.table-light
                            tr
                                th Product
                                th Price
                                th Quantity
                                th Subtotal
                                th Actions
                        tbody
                            each item in cart
                                tr
                                    td
                                        .d-flex.align-items-center
                                            img.me-3(src=item.image, alt=item.name, style="width: 50px; height: 50px; object-fit: cover;")
                                            div
                                                h6.mb-0= item.name
                                                small.text-muted= item.category
                                    td= `$${item.price}`
                                    td
                                        form(action=`/cart/update/${item._id}`, method='post', style="width: 100px;")
                                            input.form-control(type='number', name='quantity', value=item.quantity, min='1', max='10', onchange='this.form.submit()')
                                    td= `$${(item.price * item.quantity).toFixed(2)}`
                                    td
                                        form(action=`/cart/remove/${item._id}`, method='post')
                                            button.btn.btn-outline-danger.btn-sm(type='submit') Remove

                - let totalPrice = cart.reduce((sum, item) => sum + parseFloat(item.price) * item.quantity, 0);
                .d-flex.justify-content-between.align-items-center.mt-4
                    h3 Total Price: $#{totalPrice.toFixed(2)}
                    .btn-group
                        a.btn.btn-outline-secondary(href='/') Continue Shopping
                        button.btn.btn-success Checkout
